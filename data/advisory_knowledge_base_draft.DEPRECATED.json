  "decision_priority_when_multiple_actions_needed": {
    "level_1_immediate": [
      "Frost alert",
      "Extreme wind (spray risk)",
      "High disease pressure (spray)"
    ],
    "level_2_urgent_24h": [
      "Irrigation (if soil moisture critical)",
      "Fungicide spray (if humidity+temp+ndvi all align)"
    ],
